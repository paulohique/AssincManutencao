############################################
# Exemplo de frontend/.env.local
############################################

# URL pública da API (usada no browser)
NEXT_PUBLIC_PY_API_URL=http://127.0.0.1:8000

# Se você acessa o frontend de fora (host) e o backend está na VM,
# use o IP/URL que o browser consegue acessar:
# NEXT_PUBLIC_PY_API_URL=http://192.168.1.50:8000

# (Opcional) URL interna da API para o Next (server-side) quando rodando em Docker
# PY_API_INTERNAL_URL=http://api:8000
PY_API_INTERNAL_URL=
