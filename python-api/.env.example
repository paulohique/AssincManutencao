############################################
# Exemplo de python-api/.env
# NÃO coloque dados reais (tokens/senhas) no repositório.
############################################

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=glpi_user
DB_PASSWORD=coloque_uma_senha_forte_aqui
DB_NAME=glpi_manutencao

# GLPI API
GLPI_BASE_URL=http://glpi.seudominio.local/glpi/apirest.php
GLPI_APP_TOKEN=COLE_SEU_APP_TOKEN_AQUI
GLPI_USER_TOKEN=COLE_SEU_USER_TOKEN_AQUI

# GLPI - Cache de tickets abertos (evita sobrecarregar o GLPI)
GLPI_TICKETS_CACHE_TTL_SECONDS=30
# Se o GLPI estiver fora, serve o último cache por um tempo (segundos)
GLPI_TICKETS_CACHE_STALE_MAX_SECONDS=600

# GLPI - Outbox (evita perder follow-up quando GLPI estiver indisponível)
# Para produção com múltiplas instâncias, prefira rodar o processador via job/cron.
GLPI_OUTBOX_WORKER_ENABLED=false
GLPI_OUTBOX_PROCESS_INTERVAL_SECONDS=60
GLPI_OUTBOX_PROCESS_BATCH_SIZE=25

# Webhook (para plugin GLPI disparar sync sem login)
# Enviado no header: X-Glpi-Webhook-Token
GLPI_WEBHOOK_TOKEN=coloque_um_segredo_grande_aqui

# Opcional: restringir IPs/CIDRs permitidos para chamar os webhooks
# Ex.: "10.0.0.10" ou "10.0.0.0/24"
GLPI_WEBHOOK_ALLOWED_IPS=10.0.0.0/24,192.168.0.0/24

# GLPI - Escrita no ticket
# Por padrão, a aplicação envia um follow-up/comentário (cinza).
# Se quiser que a mensagem seja registrada como SOLUÇÃO (azul), sem mudar o status do ticket:
GLPI_SEND_AS_SOLUTION=true
# Opcional: ID do tipo de solução (solutiontypes_id) do seu GLPI.
GLPI_SOLUTION_TYPE_ID=0

# App
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
MAINTENANCE_INTERVAL_DAYS=365

# Auth (LDAP/AD + JWT)
AUTH_ENABLED=true
JWT_SECRET=troque_este_valor_por_um_segredo_grande
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Login
# Quando true, se o login local falhar o backend tenta autenticar no LDAP/AD.
LOGIN_ALLOW_LDAP=true

# LDAP (Active Directory)
# Exemplos:
# LDAP_SERVER=ldap://dc01.seudominio.local
# LDAP_SERVER=ldaps://dc01.seudominio.local
LDAP_SERVER=ldap://dc01.seudominio.local
LDAP_BASE_DN=DC=seudominio,DC=local
LDAP_DOMAIN=seudominio.local
LDAP_USE_SSL=false
LDAP_CONNECT_TIMEOUT_SECONDS=10
