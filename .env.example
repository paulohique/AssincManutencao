############################################
# Exemplo de .env (Docker/stack)
# NÃO coloque dados reais (tokens/senhas) no repositório.
############################################

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=glpi_user
DB_PASSWORD=coloque_uma_senha_forte_aqui
DB_NAME=glpi_manutencao

# Docker (MySQL)
MYSQL_ROOT_PASSWORD=root

# GLPI API
GLPI_BASE_URL=http://glpi.seudominio.local/glpi/apirest.php
GLPI_APP_TOKEN=COLE_SEU_APP_TOKEN_AQUI
GLPI_USER_TOKEN=COLE_SEU_USER_TOKEN_AQUI

# GLPI - Cache/Outbox/Webhook
GLPI_TICKETS_CACHE_TTL_SECONDS=30
GLPI_TICKETS_CACHE_STALE_MAX_SECONDS=600
GLPI_OUTBOX_WORKER_ENABLED=false
GLPI_OUTBOX_PROCESS_INTERVAL_SECONDS=60
GLPI_OUTBOX_PROCESS_BATCH_SIZE=25
GLPI_WEBHOOK_TOKEN=coloque_um_segredo_grande_aqui
GLPI_WEBHOOK_ALLOWED_IPS=10.0.0.0/24

# GLPI - Escrita no ticket
GLPI_SEND_AS_SOLUTION=true
GLPI_SOLUTION_TYPE_ID=0

# App
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAINTENANCE_INTERVAL_DAYS=365

# Auth (LDAP/AD + JWT)
AUTH_ENABLED=true
JWT_SECRET=troque_este_valor_por_um_segredo_grande
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Login/LDAP
LOGIN_ALLOW_LDAP=true
LDAP_SERVER=ldap://dc01.seudominio.local
LDAP_BASE_DN=DC=seudominio,DC=local
LDAP_DOMAIN=seudominio.local
LDAP_USE_SSL=false
LDAP_CONNECT_TIMEOUT_SECONDS=10

# Frontend (Next.js)
NEXT_PUBLIC_PY_API_URL=http://localhost:8000
PY_API_INTERNAL_URL=http://api:8000
